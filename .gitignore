# ═══════════════════════════════════════════════════════════════
runs/
logs/
*.log

# ═══════════════════════════════════════════════════════════════
# Environment & Secrets
# ═══════════════════════════════════════════════════════════════
.env
.env.local
.env.production
backend/.env

# ═══════════════════════════════════════════════════════════════
