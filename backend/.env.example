# Courier Optimizer Configuration
# Copy to .env and customize

# Server
COURIER_HOST=0.0.0.0
COURIER_PORT=8000
COURIER_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data
COURIER_DATA_FILE=address_extraction_results.csv
COURIER_TARGET_DATE=2025-10-15

# Fleet
COURIER_NUM_COURIERS=20
COURIER_MIN_PER_COURIER=10
COURIER_MAX_PER_COURIER=20
COURIER_N_DELIVERIES=308
COURIER_RANDOM_SEED=42

# Weights
COURIER_ALPHA=0.99
COURIER_BETA=0.01
COURIER_GAMMA=0.0
COURIER_DELTA=0.0

# Pipeline
COURIER_LNS_ITERS=32
COURIER_SA_ITERS=6000
COURIER_DEBUG=false
